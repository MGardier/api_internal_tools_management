{
  "info": {
    "name": "Internal Tools Management API",
    "description": "Collection for testing the Internal Tools Management API. Set the `baseUrl` collection variable to your running server (default: http://localhost:3000/api). One canonical request per endpoint — edit query params, path params, or body inline to exercise other cases (filters, validation errors, etc.).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Tools",
      "description": "Endpoints for the tool catalog.",
      "item": [
        {
          "name": "GET /tools — list",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                {
                  "key": "department",
                  "value": "Engineering",
                  "description": "Engineering | Sales | Marketing | HR | Finance | Operations | Design",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "active",
                  "description": "active | deprecated | trial",
                  "disabled": true
                },
                {
                  "key": "category",
                  "value": "Design",
                  "description": "Exact category name (case-sensitive)",
                  "disabled": true
                },
                {
                  "key": "min_cost",
                  "value": "10",
                  "description": "Minimum monthly cost (>= 0)",
                  "disabled": true
                },
                {
                  "key": "max_cost",
                  "value": "500",
                  "description": "Maximum monthly cost (must be >= min_cost when both set)",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "name",
                  "description": "cost | name | date (default: name)",
                  "disabled": true
                },
                {
                  "key": "order",
                  "value": "asc",
                  "description": "asc | desc (default: asc)",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number, 1-indexed (default: 1)",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Items per page, 1-100 (default: 20)",
                  "disabled": true
                }
              ]
            },
            "description": "Paginated list of tools with filters and sorting. All query params are optional — enable them in the Params tab to combine filters. Errors: 400 on invalid enum, max_cost < min_cost, unknown param (forbidNonWhitelisted)."
          },
          "response": []
        },
        {
          "name": "GET /tools/:id — detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "description": "Full detail of a single tool, including 30-day usage metrics and total monthly cost. Errors: 400 if id is not a positive integer (PositiveIntPipe); 404 if the tool does not exist."
          },
          "response": []
        },
        {
          "name": "POST /tools — create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Linear\",\n  \"description\": \"Issue tracking and project management\",\n  \"vendor\": \"Linear\",\n  \"website_url\": \"https://linear.app\",\n  \"category_id\": 2,\n  \"monthly_cost\": 8.0,\n  \"owner_department\": \"Engineering\"\n}"
            },
            "description": "Creates a tool. Required: name, vendor, category_id, monthly_cost, owner_department. Optional: description, website_url. Status is forced to 'active' server-side. Errors: 400 on body validation or unknown category_id (details.category_id); 409 if a tool with the same name (case-insensitive) already exists."
          },
          "response": []
        },
        {
          "name": "PATCH /tools/:id — update",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthly_cost\": 12.5,\n  \"status\": \"deprecated\"\n}"
            },
            "description": "Partial update — all fields optional. Editable: description, vendor, website_url, category_id, monthly_cost, owner_department, status. The 'name' field is not editable (rejected by forbidNonWhitelisted). An empty body {} is a valid no-op (returns 200 with the current tool; updated_at is bumped via @updatedAt). Errors: 404 if the tool does not exist; 400 on body validation or unknown category_id (details.category_id)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Docs",
      "description": "Swagger / OpenAPI references.",
      "item": [
        {
          "name": "GET /docs - Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/docs",
              "host": ["{{baseUrl}}"],
              "path": ["docs"]
            },
            "description": "Open the Swagger UI in your browser."
          },
          "response": []
        },
        {
          "name": "GET /docs-json - OpenAPI spec",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/docs-json",
              "host": ["{{baseUrl}}"],
              "path": ["docs-json"]
            },
            "description": "Raw OpenAPI JSON spec."
          },
          "response": []
        }
      ]
    }
  ]
}
