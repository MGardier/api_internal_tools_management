{
  "info": {
    "name": "Internal Tools Management API",
    "description": "Collection for testing the Internal Tools Management API. Set the `baseUrl` collection variable to your running server (default: http://localhost:3000/api).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Tools",
      "description": "Endpoints for the tool catalog.",
      "item": [
        {
          "name": "GET /tools - list all (defaults)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "description": "List tools with default pagination (page=1, limit=20) and default sort (name asc)."
          },
          "response": []
        },
        {
          "name": "GET /tools - filter by department",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?department=Engineering",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                {
                  "key": "department",
                  "value": "Engineering",
                  "description": "One of: Engineering, Sales, Marketing, HR, Finance, Operations, Design"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /tools - filter by status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?status=active",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                {
                  "key": "status",
                  "value": "active",
                  "description": "One of: active, deprecated, trial"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /tools - filter by category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?category=Design",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                {
                  "key": "category",
                  "value": "Design"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /tools - filter by cost range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?min_cost=10&max_cost=500",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                { "key": "min_cost", "value": "10" },
                { "key": "max_cost", "value": "500" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /tools - sort by cost desc",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?sort=cost&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                {
                  "key": "sort",
                  "value": "cost",
                  "description": "One of: cost, name, date"
                },
                {
                  "key": "order",
                  "value": "desc",
                  "description": "One of: asc, desc"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /tools - pagination (page 2, limit 5)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?page=2&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET /tools - combined filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?department=Engineering&status=active&min_cost=0&max_cost=1000&sort=cost&order=desc&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                { "key": "department", "value": "Engineering" },
                { "key": "status", "value": "active" },
                { "key": "min_cost", "value": "0" },
                { "key": "max_cost", "value": "1000" },
                { "key": "sort", "value": "cost" },
                { "key": "order", "value": "desc" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "All filters and options combined in a single request."
          },
          "response": []
        },
        {
          "name": "GET /tools - 400 max_cost < min_cost",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?min_cost=500&max_cost=100",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                { "key": "min_cost", "value": "500" },
                { "key": "max_cost", "value": "100" }
              ]
            },
            "description": "Expects a 400 Bad Request: max_cost must be >= min_cost."
          },
          "response": []
        },
        {
          "name": "GET /tools - 400 invalid enum",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?department=Unknown",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                { "key": "department", "value": "Unknown" }
              ]
            },
            "description": "Expects a 400 Bad Request: department is not a valid enum value."
          },
          "response": []
        },
        {
          "name": "GET /tools - 400 unknown param",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools?foo=bar",
              "host": ["{{baseUrl}}"],
              "path": ["tools"],
              "query": [
                { "key": "foo", "value": "bar" }
              ]
            },
            "description": "Expects a 400 Bad Request: unknown query parameter (forbidNonWhitelisted)."
          },
          "response": []
        },
        {
          "name": "GET /tools/:id - found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "description": "Returns the full detail of tool 1, including 30-day usage metrics."
          },
          "response": []
        },
        {
          "name": "GET /tools/:id - 404 not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools/999999",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "999999"]
            },
            "description": "Expects a 404 Not Found when the tool ID does not exist."
          },
          "response": []
        },
        {
          "name": "GET /tools/:id - 400 invalid id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tools/abc",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "abc"]
            },
            "description": "Expects a 400 Bad Request: id must be a positive integer (PositiveIntPipe)."
          },
          "response": []
        },
        {
          "name": "POST /tools - 201 created (full body)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Linear\",\n  \"description\": \"Issue tracking and project management\",\n  \"vendor\": \"Linear\",\n  \"website_url\": \"https://linear.app\",\n  \"category_id\": 2,\n  \"monthly_cost\": 8.0,\n  \"owner_department\": \"Engineering\"\n}"
            },
            "description": "Creates a new tool with all fields. Status is set to 'active' server-side."
          },
          "response": []
        },
        {
          "name": "POST /tools - 201 created (minimal body)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MinimalTool\",\n  \"vendor\": \"Acme\",\n  \"category_id\": 1,\n  \"monthly_cost\": 0,\n  \"owner_department\": \"Operations\"\n}"
            },
            "description": "Creates a tool with only required fields (description and website_url omitted)."
          },
          "response": []
        },
        {
          "name": "POST /tools - 400 missing required fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Incomplete\"\n}"
            },
            "description": "Expects a 400 Bad Request: vendor, category_id, monthly_cost, owner_department are required."
          },
          "response": []
        },
        {
          "name": "POST /tools - 400 category does not exist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"GhostCategoryTool\",\n  \"vendor\": \"Acme\",\n  \"category_id\": 999999,\n  \"monthly_cost\": 5,\n  \"owner_department\": \"Engineering\"\n}"
            },
            "description": "Expects a 400 Bad Request with details.category_id when the referenced category does not exist."
          },
          "response": []
        },
        {
          "name": "POST /tools - 409 name already exists",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"figma\",\n  \"vendor\": \"Figma Inc.\",\n  \"category_id\": 1,\n  \"monthly_cost\": 15,\n  \"owner_department\": \"Design\"\n}"
            },
            "description": "Expects a 409 Conflict: case-insensitive name collision (e.g. 'figma' vs existing 'Figma')."
          },
          "response": []
        },
        {
          "name": "POST /tools - 400 invalid website_url",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools",
              "host": ["{{baseUrl}}"],
              "path": ["tools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"BadUrlTool\",\n  \"vendor\": \"Acme\",\n  \"website_url\": \"not-a-url\",\n  \"category_id\": 1,\n  \"monthly_cost\": 5,\n  \"owner_department\": \"Engineering\"\n}"
            },
            "description": "Expects a 400 Bad Request: website_url must be a valid URL."
          },
          "response": []
        },
        {
          "name": "PATCH /tools/:id - 200 partial update",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthly_cost\": 12.5,\n  \"owner_department\": \"Engineering\"\n}"
            },
            "description": "Updates only the provided fields. Other fields are left untouched."
          },
          "response": []
        },
        {
          "name": "PATCH /tools/:id - 200 empty body (no-op)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "description": "Empty body is valid and returns 200 with the current tool (no fields change; updated_at is bumped via @updatedAt)."
          },
          "response": []
        },
        {
          "name": "PATCH /tools/:id - 404 tool not found",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools/999999",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "999999"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthly_cost\": 10\n}"
            },
            "description": "Expects a 404 Not Found when the tool ID does not exist."
          },
          "response": []
        },
        {
          "name": "PATCH /tools/:id - 400 category does not exist",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 999999\n}"
            },
            "description": "Expects a 400 Bad Request with details.category_id when the new category does not exist."
          },
          "response": []
        },
        {
          "name": "PATCH /tools/:id - 400 name is forbidden",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tools/1",
              "host": ["{{baseUrl}}"],
              "path": ["tools", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"NewName\"\n}"
            },
            "description": "Expects a 400 Bad Request: name is not allowed in updates (rejected by forbidNonWhitelisted since UpdateToolRequestDto omits name)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Docs",
      "description": "Swagger / OpenAPI references.",
      "item": [
        {
          "name": "GET /docs - Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/docs",
              "host": ["{{baseUrl}}"],
              "path": ["docs"]
            },
            "description": "Open the Swagger UI in your browser."
          },
          "response": []
        },
        {
          "name": "GET /docs-json - OpenAPI spec",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/docs-json",
              "host": ["{{baseUrl}}"],
              "path": ["docs-json"]
            },
            "description": "Raw OpenAPI JSON spec."
          },
          "response": []
        }
      ]
    }
  ]
}
