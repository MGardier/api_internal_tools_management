{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testTimeout": 30000,
  "testRegex": "test/integration/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/(.*)$": "<rootDir>/../src/app/$1",
    "^@modules/(.*)$": "<rootDir>/../src/modules/$1",
    "^@shared/(.*)$": "<rootDir>/../src/shared/$1",
    "^@db/(.*)$": "<rootDir>/../prisma/$1"
  }
}
