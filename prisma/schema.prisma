generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model AccessRequest {
  id                    Int                @id @default(autoincrement())
  userId                Int                @map("user_id")
  toolId                Int                @map("tool_id")
  businessJustification String             @map("business_justification")
  status                RequestStatusType? @default(pending)
  requestedAt           DateTime?          @default(now()) @map("requested_at") @db.Timestamp(6)
  processedAt           DateTime?          @map("processed_at") @db.Timestamp(6)
  processedBy           Int?               @map("processed_by")
  processingNotes       String?            @map("processing_notes")
  processedByUser       User?              @relation("AccessRequestProcessedBy", fields: [processedBy], references: [id], onUpdate: NoAction)
  tool                  Tool               @relation(fields: [toolId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                  User               @relation("AccessRequestUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([requestedAt], map: "idx_requests_date")
  @@index([status], map: "idx_requests_status")
  @@index([userId], map: "idx_requests_user")
  @@map("access_requests")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  description String?
  colorHex    String?   @default("#6366f1") @map("color_hex") @db.VarChar(7)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  tools       Tool[]

  @@map("categories")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model CostTracking {
  id               Int       @id @default(autoincrement())
  toolId           Int       @map("tool_id")
  monthYear        DateTime  @map("month_year") @db.Date
  totalMonthlyCost Decimal   @map("total_monthly_cost") @db.Decimal(10, 2)
  activeUsersCount Int       @default(0) @map("active_users_count")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  tool             Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([toolId, monthYear])
  @@index([monthYear, toolId], map: "idx_cost_month_tool")
  @@map("cost_tracking")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Tool {
  id               Int              @id @default(autoincrement())
  name             String           @unique @db.VarChar(100)
  description      String?
  vendor           String           @db.VarChar(100)
  websiteUrl       String?          @map("website_url") @db.VarChar(255)
  categoryId       Int              @map("category_id")
  monthlyCost      Decimal          @map("monthly_cost") @db.Decimal(10, 2)
  activeUsersCount Int              @default(0) @map("active_users_count")
  ownerDepartment  DepartmentType   @map("owner_department")
  status           ToolStatusType   @default(active)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime         @default(now()) @map("updated_at") @db.Timestamp(6)
  accessRequests   AccessRequest[]
  costTracking     CostTracking[]
  category         Category         @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  usageLogs        UsageLog[]
  userToolAccesses UserToolAccess[]

  @@index([activeUsersCount(sort: Desc)], map: "idx_tools_active_users")
  @@index([categoryId], map: "idx_tools_category")
  @@index([monthlyCost(sort: Desc)], map: "idx_tools_cost_desc")
  @@index([ownerDepartment], map: "idx_tools_department")
  @@index([status], map: "idx_tools_status")
  @@map("tools")
}

model UsageLog {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  toolId       Int       @map("tool_id")
  sessionDate  DateTime  @map("session_date") @db.Date
  usageMinutes Int?      @default(0) @map("usage_minutes")
  actionsCount Int?      @default(0) @map("actions_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sessionDate, toolId], map: "idx_usage_date_tool")
  @@index([userId, sessionDate], map: "idx_usage_user_date")
  @@map("usage_logs")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model UserToolAccess {
  id            Int               @id @default(autoincrement())
  userId        Int               @map("user_id")
  toolId        Int               @map("tool_id")
  grantedAt     DateTime?         @default(now()) @map("granted_at") @db.Timestamp(6)
  grantedBy     Int               @map("granted_by")
  revokedAt     DateTime?         @map("revoked_at") @db.Timestamp(6)
  revokedBy     Int?              @map("revoked_by")
  status        AccessStatusType? @default(active)
  grantedByUser User              @relation("UserToolAccessGrantedBy", fields: [grantedBy], references: [id], onUpdate: NoAction)
  revokedByUser User?             @relation("UserToolAccessRevokedBy", fields: [revokedBy], references: [id], onUpdate: NoAction)
  tool          Tool              @relation(fields: [toolId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user          User              @relation("UserToolAccessUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, toolId, status])
  @@index([grantedAt], map: "idx_access_granted_date")
  @@index([status], map: "idx_access_status")
  @@index([toolId], map: "idx_access_tool")
  @@index([userId], map: "idx_access_user")
  @@map("user_tool_access")
}

model User {
  id                      Int              @id @default(autoincrement())
  name                    String           @db.VarChar(100)
  email                   String           @unique @db.VarChar(150)
  department              DepartmentType
  role                    UserRoleType?    @default(employee)
  status                  UserStatusType?  @default(active)
  hireDate                DateTime?        @map("hire_date") @db.Date
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime         @default(now()) @map("updated_at") @db.Timestamp(6)
  accessRequestsProcessed AccessRequest[]  @relation("AccessRequestProcessedBy")
  accessRequests          AccessRequest[]  @relation("AccessRequestUser")
  usageLogs               UsageLog[]
  userToolAccessesGranted UserToolAccess[] @relation("UserToolAccessGrantedBy")
  userToolAccessesRevoked UserToolAccess[] @relation("UserToolAccessRevokedBy")
  userToolAccesses        UserToolAccess[] @relation("UserToolAccessUser")

  @@index([department], map: "idx_users_department")
  @@index([status], map: "idx_users_status")
  @@map("users")
}

enum AccessStatusType {
  active
  revoked

  @@map("access_status_type")
}

enum DepartmentType {
  Engineering
  Sales
  Marketing
  HR
  Finance
  Operations
  Design

  @@map("department_type")
}

enum RequestStatusType {
  pending
  approved
  rejected

  @@map("request_status_type")
}

enum ToolStatusType {
  active
  deprecated
  trial

  @@map("tool_status_type")
}

enum UserRoleType {
  employee
  manager
  admin

  @@map("user_role_type")
}

enum UserStatusType {
  active
  inactive

  @@map("user_status_type")
}
